{
  "env": {
    "NEXT_TELEMETRY_DISABLED": "1"
  },
  "build": {
    "env": {
      "NEXT_TELEMETRY_DISABLED": "1"
    }
  },
  "crons": [
    {
      "path": "/api/cron/fetch-trending",
      "schedule": "0 16 * * *"
    },
    {
      "path": "/api/cron/fetch-hot",
      "schedule": "30 16 * * *"
    },
    {
      "path": "/api/cron/translate-new",
      "schedule": "0 17 * * *"
    },
    {
      "path": "/api/cron/cleanup",
      "schedule": "0 3 * * 0"
    }
  ]
}
